        -- Add code here to detect staff members
    else
        print("Staff Detector disabled")
        -- Remove code here to detect staff members
    end
end

-- Connect the toggle buttons to their respective functions
aimbotToggle.MouseButton1Click:Connect(toggleAimbot)
noRecoilToggle.MouseButton1Click:Connect(toggleNoRecoil)
invisibilityToggle.MouseButton1Click:Connect(toggleInvisibility)
staffDetectorToggle.MouseButton1Click:Connect(toggleStaffDetector)

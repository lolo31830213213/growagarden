local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Table des clés valides (key -> {staffLevel, isInvisible})
local validKeys = {
    ["ADMIN_KEY"] = {10, true},  -- Exemple de clé d'admin
    ["KEY123"] = {5, false}      -- Exemple de clé standard
}

-- Webhook URL pour les notifications
local webhookURL = "https://your-webhook-url.com"

-- Fonction pour envoyer des notifications via webhook
local function sendWebhookMessage(message)
    local httpService = game:GetService("HttpService")
    local jsonBody = {content = message}
    httpService:PostAsync(webhookURL, httpService:JSONEncode(jsonBody))
end

-- Fonction de vérification de l'HWID et du niveau de staff
local function verifyKey(player, key)
    if validKeys[key] then
        local staffLevel, isInvisible = validKeys[key]
        -- Vérifier si le joueur a déjà un staff level ou est invisible
        if player:FindFirstChild("StaffLevel") or player:FindFirstChild("IsInvisible") then
            sendWebhookMessage(player.Name .. " already has a staff level or is invisible.")
            return false
        end
        
        -- Appliquer les effets du cheat
        player:SetAttribute("StaffLevel", staffLevel)
        player:SetAttribute("IsInvisible", isInvisible)
        
        sendWebhookMessage(player.Name .. " verified and has been granted Staff Level " .. staffLevel .. ". Invisible: " .. tostring(isInvisible))
        return true
    else
        sendWebhookMessage(player.Name .. " entered an invalid key.")
        return false
    end
end

-- Fonction pour réinitialiser les attributs de cheat
local function resetCheatAttributes(player)
    player:SetAttribute("StaffLevel", nil)
    player:SetAttribute("IsInvisible", nil)
end

-- Créer un menu pour accéder aux options
local function createMenu()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Parent = game.Players.LocalPlayer.PlayerGui
    
    -- Menu principal
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0.3, 0, 0.2, 0)
    mainFrame.Position = UDim2.new(0.35, 0, 0.4, 0)
    mainFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    mainFrame.Parent = screenGui
    
    -- Titre du menu
    local title = Instance.new("TextLabel")
    title.Text = "Cheat Menu"
    title.Size = UDim2.new(1, 0, 0.3, 0)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.BackgroundColor3 = Color3.fromRGB(0, 0, 255)
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Font = Enum.Font.SourceSansBold
    title.Parent = mainFrame
    
    -- Input box pour entrer la clé
    local inputBox = Instance.new("TextBox")
    inputBox.Size = UDim2.new(1, -20, 0.3, 0)
    inputBox.Position = UDim2.new(0, 10, 0.4, 0)
    inputBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    inputBox.PlaceholderText = "Enter key..."
    inputBox.Parent = mainFrame
    
    -- Bouton pour vérifier la clé
    local verifyButton = Instance.new("TextButton")
    verifyButton.Text = "Verify"
    verifyButton.Size = UDim2.new(1, -20, 0.3, 0)
    verifyButton.Position = UDim2.new(0, 10, 0.8, 0)
    verifyButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    verifyButton.Parent = mainFrame
    
    -- Fonction pour gérer les entrées
    local function onInputChanged(text)
        if text:match("^%S+$") and text ~= "" then
            inputBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255) -- Normal
        else
            inputBox.BackgroundColor3 = Color3.fromRGB(255, 0, 0)     -- Erreur
        end
    end
    
    -- Fonction pour vérifier la clé lors de l'appui sur Entrée ou le clic sur le bouton
    local function onButtonClicked()
        local key = inputBox.Text
        if key ~= "" then
            verifyKey(game.Players.LocalPlayer, key)
        else
            sendWebhookMessage("LocalPlayer tried to verify an empty key.")
        end
    end
    
    -- Connecter les fonctions aux événements d'entrée et de clic
    inputBox.Changed:Connect(onInputChanged)
    verifyButton.MouseButton1Click:Connect(onButtonClicked)
end

-- Créer le menu au démarrage du jeu
createMenu()

-- Réinitialiser les attributs de cheat si le joueur quitte le jeu
Players.LocalPlayer.CharacterAdded:Connect(function(character)
    resetCheatAttributes(Players.LocalPlayer)
end)

-- Initialize AimBot and No Recoil states
local aimbotEnabled = false
local noRecoilActive = false
local invisibilityActive = false
local staffDetectorActive = false

-- Function to toggle AimBot
local function toggleAimbot()
    aimbotEnabled = not aimbotEnabled
    if aimbotEnabled then
        print("AimBot enabled")
    else
        print("AimBot disabled")
        UserInputService.MouseDelta = Vector2.new(0, 0)
    end
end

-- Function to toggle No Recoil
local function toggleNoRecoil()
    noRecoilActive = not noRecoilActive
    if noRecoilActive then
        print("No Recoil enabled")
    else
        print("No Recoil disabled")
    end
end

-- Function to toggle Invisibility
local function toggleInvisibility()
    invisibilityActive = not invisibilityActive
    if invisibilityActive then
        print("Invisibility enabled")
        game.Players.LocalPlayer.Character.Head.Transparency = 1
        game.Players.LocalPlayer.Character.UpperTorso.Transparency = 0.5
        game.Players.LocalPlayer.Character.LowerTorso.Transparency = 0.5
        game.Players.LocalPlayer.Character.RightUpperArm.Transparency = 0.5
        game.Players.LocalPlayer.Character.LeftUpperArm.Transparency = 0.5
        game.Players.LocalPlayer.Character.RightLowerArm.Transparency = 0.5
        game.Players.LocalPlayer.Character.LeftLowerArm.Transparency = 0.5
        game.Players.LocalPlayer.Character.RightHand.Transparency = 1
        game.Players.LocalPlayer.Character.LeftHand.Transparency = 1
    else
        print("Invisibility disabled")
        game.Players.LocalPlayer.Character.Head.Transparency = 0
        game.Players.LocalPlayer.Character.UpperTorso.Transparency = 0
        game.Players.LocalPlayer.Character.LowerTorso.Transparency = 0
        game.Players.LocalPlayer.Character.RightUpperArm.Transparency = 0
        game.Players.LocalPlayer.Character.LeftUpperArm.Transparency = 0
        game.Players.LocalPlayer.Character.RightLowerArm.Transparency = 0
        game.Players.LocalPlayer.Character.LeftLowerArm.Transparency = 0
        game.Players.LocalPlayer.Character.RightHand.Transparency = 0
        game.Players.LocalPlayer.Character.LeftHand.Transparency = 0
    end
end

-- Function to toggle Staff Detector
local function toggleStaffDetector()
    staffDetectorActive = not staffDetectorActive
    if staffDetectorActive then
